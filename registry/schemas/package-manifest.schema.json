{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qintopia.local/schemas/package-manifest.schema.json",
  "title": "Qintopia Agent OS Package Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "name",
    "owner",
    "status",
    "risk_level",
    "description",
    "source",
    "production_boundary",
    "validation",
    "next_actions"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^(agents|skills|workflows|mcp|runtime|deploy|deprecated)/[a-z0-9][a-z0-9-]*(/[a-z0-9][a-z0-9-]*)?$"
    },
    "type": {
      "enum": ["agent", "skill", "workflow", "mcp", "runtime", "deploy", "deprecated"]
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": ["draft", "adopting", "active", "deprecated", "removed"]
    },
    "risk_level": {
      "enum": ["low", "medium", "high"]
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["disposition"],
      "properties": {
        "path": {
          "type": "string"
        },
        "reference": {
          "type": "string"
        },
        "disposition": {
          "enum": [
            "adopt",
            "template",
            "runtime-only",
            "review-pool",
            "deprecated",
            "remove"
          ]
        }
      }
    },
    "production_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["external_sends", "database_writes", "runtime_profile", "secrets"],
      "properties": {
        "external_sends": {
          "type": "boolean"
        },
        "database_writes": {
          "type": "boolean"
        },
        "runtime_profile": {
          "type": "boolean"
        },
        "secrets": {
          "type": "boolean"
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commands"],
      "properties": {
        "commands": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "next_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
