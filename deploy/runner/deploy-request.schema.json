{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qintopia-agent-os.local/schemas/deploy-request.schema.json",
  "title": "Qintopia Agent OS Deploy Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_id",
    "environment",
    "repository",
    "requested_by",
    "created_at",
    "expires_at",
    "commit_sha",
    "runtime_sha",
    "deploy_bundle_sha",
    "release_sha",
    "release_scope",
    "restart_targets",
    "rollback_on_smoke_failure",
    "dry_run",
    "cos"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "request_id": {
      "type": "string",
      "pattern": "^deploy-[0-9]{8}T[0-9]{6}Z-[0-9a-f]{7,40}$"
    },
    "environment": { "enum": ["production"] },
    "repository": { "const": "qintopia-agent-studio/qintopia-agent-os" },
    "requested_by": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" },
    "commit_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "runtime_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "deploy_bundle_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "release_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "release_scope": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": ["sidecar-runtime", "deploy-bundle", "hermes-plugins"]
      }
    },
    "restart_targets": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "qintopia-system-services",
          "hermes-erhua",
          "hermes-wenyuange",
          "hermes-xiaoman",
          "hermes-silaoshi",
          "hermes-huabaosi",
          "hermes-guanerye"
        ]
      }
    },
    "rollback_on_smoke_failure": { "type": "boolean" },
    "dry_run": { "type": "boolean" },
    "cos": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bucket", "region", "prefix", "request_key", "result_key"],
      "properties": {
        "bucket": { "type": "string", "minLength": 1 },
        "region": { "type": "string", "minLength": 1 },
        "prefix": { "type": "string", "minLength": 1 },
        "request_key": {
          "type": "string",
          "pattern": "^qintopia-agent-os/deploy-requests/production/pending/.+\\.json$"
        },
        "result_key": {
          "type": "string",
          "pattern": "^qintopia-agent-os/deploy-results/production/.+\\.json$"
        }
      }
    },
    "github": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "workflow": { "type": "string" },
        "run_id": { "type": "string" },
        "run_attempt": { "type": "string" },
        "ref": { "type": "string" },
        "sha": { "type": "string" }
      }
    },
    "notes": { "type": "string" }
  }
}
