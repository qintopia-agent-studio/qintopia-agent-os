#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="${QINTOPIA_DEPLOY_RUNNER_STATE_DIR:-/var/lib/qintopia-agent-os-deploy}"
REQUEST_DIR="${STATE_DIR}/requests"
RESULT_DIR="${STATE_DIR}/results"
LOCK_FILE="${STATE_DIR}/deploy.lock"
RELEASE_ROOT="${QINTOPIA_RELEASE_ROOT:-/home/ubuntu/qintopia-agent-os-releases}"
ENV_FILE="${QINTOPIA_COS_ENV_FILE:-/etc/qintopia/cos-artifacts.env}"

usage() {
  cat <<'USAGE'
Usage:
  qintopia-agent-os-deploy-runner --request-file <file> [--dry-run]

Runs the fixed Qintopia Agent OS release promotion flow for a validated deploy request.
This command is intended for a root-owned systemd service or timer. It does not execute
arbitrary request commands.
USAGE
}

request_file=""
force_dry_run=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    --request-file)
      request_file="${2:-}"
      shift 2
      ;;
    --dry-run)
      force_dry_run=true
      shift
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    *)
      echo "unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if [[ -z "$request_file" || ! -f "$request_file" ]]; then
  echo "--request-file must point to an existing deploy request JSON" >&2
  exit 2
fi

mkdir -p "$REQUEST_DIR" "$RESULT_DIR" "$RELEASE_ROOT" "$(dirname "$LOCK_FILE")"

if [[ -f "$ENV_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$ENV_FILE"
fi

json_get() {
  python3 - "$request_file" "$1" <<'PY'
import json
import sys
with open(sys.argv[1], encoding="utf-8") as fh:
    data = json.load(fh)
value = data
for part in sys.argv[2].split("."):
    value = value[part]
if isinstance(value, list):
    print(",".join(value))
else:
    print(str(value).lower() if isinstance(value, bool) else value)
PY
}

validate_request() {
  python3 - "$request_file" <<'PY'
import hmac
import hashlib
import json
import os
import re
import sys
from datetime import datetime, timezone

path = sys.argv[1]
allowed_scope = {"sidecar-runtime", "deploy-bundle", "hermes-plugins"}
allowed_targets = {
    "qintopia-system-services",
    "hermes-erhua",
    "hermes-wenyuange",
    "hermes-xiaoman",
    "hermes-silaoshi",
    "hermes-huabaosi",
    "hermes-guanerye",
}
sha = re.compile(r"^[0-9a-f]{40}$")
request_id = re.compile(r"^deploy-[0-9]{8}T[0-9]{6}Z-[0-9a-f]{7,40}$")

def fail(message):
    raise SystemExit(f"invalid deploy request: {message}")

def require_string(data, key):
    value = data.get(key)
    if not isinstance(value, str) or not value:
        fail(f"{key} must be a non-empty string")
    return value

def parse_datetime(value, key):
    try:
        return datetime.fromisoformat(value.replace("Z", "+00:00"))
    except ValueError:
        fail(f"{key} must be an ISO date-time")

def canonical_json(value):
    if isinstance(value, list):
        return "[" + ",".join(canonical_json(item) for item in value) + "]"
    if isinstance(value, dict):
        return "{" + ",".join(
            json.dumps(key, separators=(",", ":")) + ":" + canonical_json(value[key])
            for key in sorted(value)
        ) + "}"
    return json.dumps(value, ensure_ascii=False, separators=(",", ":"))

def signing_envelope(request, signature_metadata):
    return {"request": request, "signature": signature_metadata}

with open(path, encoding="utf-8") as fh:
    data = json.load(fh)

if data.get("schema_version") != 1:
    fail("schema_version must be 1")
if data.get("environment") != "production":
    fail("environment must be production")
if data.get("repository") != "qintopia-agent-studio/qintopia-agent-os":
    fail("repository mismatch")
if not request_id.fullmatch(require_string(data, "request_id")):
    fail("request_id format mismatch")
for key in ("commit_sha", "runtime_sha", "deploy_bundle_sha", "release_sha"):
    if not sha.fullmatch(require_string(data, key)):
        fail(f"{key} must be a lowercase 40-character SHA")

created_at = parse_datetime(require_string(data, "created_at"), "created_at")
expires_at = parse_datetime(require_string(data, "expires_at"), "expires_at")
now = datetime.now(timezone.utc)
if created_at.tzinfo is None or expires_at.tzinfo is None:
    fail("created_at and expires_at must include timezone")
if expires_at <= now:
    fail("request is expired")
if expires_at <= created_at:
    fail("expires_at must be after created_at")

release_scope = data.get("release_scope")
if not isinstance(release_scope, list) or not release_scope:
    fail("release_scope must be a non-empty list")
if set(release_scope) - allowed_scope or len(set(release_scope)) != len(release_scope):
    fail("release_scope contains unsupported or duplicate entries")

restart_targets = data.get("restart_targets")
if not isinstance(restart_targets, list) or not restart_targets:
    fail("restart_targets must be a non-empty list")
if set(restart_targets) - allowed_targets or len(set(restart_targets)) != len(restart_targets):
    fail("restart_targets contains unsupported or duplicate entries")

for key in ("rollback_on_smoke_failure", "dry_run"):
    if not isinstance(data.get(key), bool):
        fail(f"{key} must be boolean")

signature = data.get("signature")
if not isinstance(signature, dict):
    fail("signature must be an object")
if signature.get("algorithm") != "hmac-sha256":
    fail("signature algorithm mismatch")
if signature.get("issuer") != "github-actions":
    fail("signature issuer mismatch")
if not isinstance(signature.get("key_id"), str) or not signature["key_id"]:
    fail("signature key_id must be a non-empty string")
expected_key_id = os.environ.get("DEPLOY_REQUEST_SIGNING_KEY_ID", "")
if not expected_key_id:
    fail("DEPLOY_REQUEST_SIGNING_KEY_ID is required")
if signature.get("key_id") != expected_key_id:
    fail("signature key_id mismatch")
signature_signed_at = parse_datetime(require_string(signature, "signed_at"), "signature.signed_at")
if signature_signed_at.tzinfo is None:
    fail("signature.signed_at must include timezone")
signature_value = require_string(signature, "value")
if not re.fullmatch(r"^[0-9a-f]{64}$", signature_value):
    fail("signature value format mismatch")
signing_key = os.environ.get("DEPLOY_REQUEST_SIGNING_KEY", "")
if not signing_key:
    fail("DEPLOY_REQUEST_SIGNING_KEY is required")
unsigned = dict(data)
signature_metadata = dict(unsigned.pop("signature", {}))
signature_metadata.pop("value", None)
expected_signature = hmac.new(
    signing_key.encode("utf-8"),
    canonical_json(signing_envelope(unsigned, signature_metadata)).encode("utf-8"),
    hashlib.sha256,
).hexdigest()
if not hmac.compare_digest(signature_value, expected_signature):
    fail("signature verification failed")

cos = data.get("cos")
if not isinstance(cos, dict):
    fail("cos must be an object")
if cos.get("prefix") != "qintopia-agent-os":
    fail("cos.prefix must be qintopia-agent-os")
expected_request_key = f"qintopia-agent-os/deploy-requests/production/requests/{data['request_id']}.json"
expected_result_key = f"qintopia-agent-os/deploy-results/production/{data['request_id']}.json"
if cos.get("request_key") != expected_request_key:
    fail("cos.request_key does not match request_id")
if cos.get("result_key") != expected_result_key:
    fail("cos.result_key does not match request_id")
require_string(cos, "bucket")
require_string(cos, "region")
expected_bucket = os.environ.get("TENCENT_COS_BUCKET")
expected_region = os.environ.get("TENCENT_COS_REGION")
if expected_bucket and cos.get("bucket") != expected_bucket:
    fail("cos.bucket does not match runner environment")
if expected_region and cos.get("region") != expected_region:
    fail("cos.region does not match runner environment")
PY
}

validate_request

request_id="$(json_get request_id)"
release_sha="$(json_get release_sha)"
runtime_sha="$(json_get runtime_sha)"
deploy_bundle_sha="$(json_get deploy_bundle_sha)"
restart_targets="$(json_get restart_targets)"
dry_run="$(json_get dry_run)"
rollback_on_smoke_failure="$(json_get rollback_on_smoke_failure)"
if [[ "$force_dry_run" == true ]]; then
  dry_run=true
fi

result_file="${RESULT_DIR}/${request_id}.json"
started_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

write_result() {
  local status="$1"
  local error="${2:-}"
  local rollback_attempted="${3:-false}"
  local rollback_status="${4:-not_needed}"
  local rollback_target="${5:-}"
  local previous_target=""
  local current_target=""
  if [[ -e "${RELEASE_ROOT}/previous" || -L "${RELEASE_ROOT}/previous" ]]; then
    previous_target="$(readlink -f "${RELEASE_ROOT}/previous" 2>/dev/null || true)"
  fi
  if [[ -e "${RELEASE_ROOT}/current" || -L "${RELEASE_ROOT}/current" ]]; then
    current_target="$(readlink -f "${RELEASE_ROOT}/current" 2>/dev/null || true)"
  fi
  previous_sha="${previous_target##*/}"
  python3 - "$result_file" "$request_id" "$status" "$started_at" \
    "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$release_sha" "$previous_sha" \
    "$current_target" "$restart_targets" "$error" "$rollback_attempted" \
    "$rollback_status" "$rollback_target" <<'PY'
import json
import sys

(
    path,
    request_id,
    status,
    started_at,
    finished_at,
    release_sha,
    previous_sha,
    current_target,
    restart_targets,
    error,
    rollback_attempted,
    rollback_status,
    rollback_target,
) = sys.argv[1:14]

result = {
    "schema_version": 1,
    "request_id": request_id,
    "environment": "production",
    "status": status,
    "started_at": started_at,
    "finished_at": finished_at,
    "release_sha": release_sha,
    "previous_sha": previous_sha,
    "current_target": current_target,
    "restart_targets": [item for item in restart_targets.split(",") if item],
    "checks": [{"name": "deploy-runner", "status": "passed" if status.endswith("succeeded") else "failed"}],
    "rollback": {
        "attempted": rollback_attempted == "true",
        "status": rollback_status,
    },
}
if rollback_target:
    result["rollback"]["target"] = rollback_target
if error:
    result["error"] = error
with open(path, "w", encoding="utf-8") as fh:
    json.dump(result, fh, ensure_ascii=False, indent=2)
    fh.write("\n")
PY
}

run_promotion() {
  promote_args=(
    --request-file "$request_file"
    --release-root "$RELEASE_ROOT"
  )
  if [[ "$dry_run" == "true" ]]; then
    promote_args+=(--dry-run)
  fi
  deploy/runner/promote-release.sh \
    "${promote_args[@]}" || return $?
  if [[ "$dry_run" == "true" ]]; then
    write_result dry_run_succeeded
  else
    promoted_current=true
    deploy/runner/smoke-release.sh --restart-targets "$restart_targets" || return $?
    write_result succeeded
  fi
}

(
  flock -n 9 || {
    echo "another deploy is already running" >&2
    exit 75
  }
  promoted_current=false
  set +e
  run_promotion
  status=$?
  set -e
  if [[ "$status" -ne 0 ]]; then
    if [[ "$promoted_current" == "true" && "$rollback_on_smoke_failure" == "true" ]]; then
      rollback_target="$(readlink -f "${RELEASE_ROOT}/previous" 2>/dev/null || true)"
      if deploy/runner/rollback-release.sh --release-root "$RELEASE_ROOT"; then
        write_result rolled_back "deployment failed and rollback succeeded" \
          true succeeded "$rollback_target"
      else
        write_result failed "deployment failed and rollback failed" \
          true failed "$rollback_target"
      fi
    else
      write_result failed "deployment failed"
    fi
    exit "$status"
  fi
) 9>"$LOCK_FILE"

echo "Deploy result: ${result_file}"
