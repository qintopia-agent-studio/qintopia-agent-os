{
  "name": "qintopia-agent-os-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Qintopia Agent OS capability/plugin monorepo.",
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"!node_modules\"",
    "registry:check": "node tools/registry/check-registry.mjs",
    "agents:check": "node tools/agents/check-agents.mjs",
    "policy:check": "node tools/policy/check-anti-drift.mjs",
    "test:qiwe": "cd skills/qiwe && PYTHONDONTWRITEBYTECODE=1 python3 -m unittest discover -s tests -v",
    "test:sidecar": "cargo test --manifest-path runtime/sidecar/Cargo.toml",
    "smoke:sidecar": "deploy/sidecar/scripts/operations-control-plane-smoke.sh && deploy/sidecar/scripts/xiaoman-activity-acceptance-smoke.sh",
    "check": "pnpm format:check && pnpm lint:md && pnpm registry:check && pnpm agents:check && pnpm policy:check && pnpm test:qiwe && pnpm test:sidecar && pnpm smoke:sidecar"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "ajv": "^8.20.0",
    "markdownlint-cli2": "^0.23.0",
    "prettier": "^3.9.4",
    "yaml": "^2.9.0"
  }
}
