QINTOPIA_SIDECAR_NATS_URL=nats://127.0.0.1:4222
QINTOPIA_SIDECAR_NATS_STREAM=QINTOPIA_QIWE_MESSAGES
QINTOPIA_SIDECAR_RAW_SUBJECT=qintopia.qiwe.raw
QINTOPIA_SIDECAR_MESSAGE_SUBJECT=qintopia.qiwe.message
QINTOPIA_SIDECAR_CONSUMER=qintopia-message-sidecar
QINTOPIA_SIDECAR_DATABASE_URL=postgres://qintopia:change-me@127.0.0.1:55432/qintopia
QINTOPIA_SIDECAR_BATCH_SIZE=25
QINTOPIA_SIDECAR_NAK_DELAY_SECONDS=30
QINTOPIA_SIDECAR_DB_MAX_CONNECTIONS=5
QINTOPIA_EMBEDDING_BASE_URL=https://livecool.net
QINTOPIA_EMBEDDING_API_KEY=replace-with-server-secret
# Optional full endpoint override for providers that do not use BASE_URL + /v1/embeddings.
# QINTOPIA_MESSAGE_EMBEDDING_ENDPOINT=https://ark.cn-beijing.volces.com/api/plan/v3/embeddings
QINTOPIA_MESSAGE_EMBEDDING_MODEL=text-embedding-3-small
QINTOPIA_MESSAGE_EMBEDDING_BATCH_SIZE=10
QINTOPIA_MESSAGE_EMBEDDING_POLL_SECONDS=10
QINTOPIA_MESSAGE_EMBEDDING_REQUEST_DELAY_MS=0
QINTOPIA_MESSAGE_EMBEDDING_MAX_ATTEMPTS=5
QINTOPIA_MESSAGE_STORE_MCP_ALLOWED_CALLER=wenyuange
# Context MCP caller allowlist. Defaults to QINTOPIA_MESSAGE_STORE_MCP_ALLOWED_CALLER
# when unset. Add erhua only after WenYuanGe validation, for example:
# QINTOPIA_CONTEXT_MCP_ALLOWED_CALLERS=wenyuange,erhua

# Xiaoman activity worker replay/shadow-read settings.
# Fixture replay is local acceptance only and does not prove production Base parity.
QINTOPIA_XIAOMAN_ACTIVITY_FIXTURE_PATH=fixtures/xiaoman_activity_records.json
QINTOPIA_XIAOMAN_ACTIVITY_USE_FEISHU_BASE=false
# Required only when QINTOPIA_XIAOMAN_ACTIVITY_USE_FEISHU_BASE=true.
QINTOPIA_XIAOMAN_ACTIVITY_FEISHU_BASE_TOKEN=replace-with-base-token
QINTOPIA_XIAOMAN_ACTIVITY_ALLOWED_FEISHU_BASE_TOKENS=replace-with-base-token
QINTOPIA_XIAOMAN_ACTIVITY_FEISHU_PLAN_TABLE_ID=replace-with-plan-table-id
QINTOPIA_XIAOMAN_ACTIVITY_FEISHU_OCCURRENCE_TABLE_ID=replace-with-occurrence-table-id
QINTOPIA_XIAOMAN_ACTIVITY_FEISHU_PROFILE_ENV_PATH=/home/ubuntu/.hermes/profiles/xiaoman/.env
# Optional guarded shadow-read smoke. This reads Feishu Base only when set to 1.
QINTOPIA_XIAOMAN_ACTIVITY_SHADOW_ENABLE=0
QINTOPIA_XIAOMAN_ACTIVITY_SHADOW_DATE=2026-06-28
# Optional record-get/material-summary probes. Keep unset unless using known safe ids.
# QINTOPIA_XIAOMAN_ACTIVITY_SHADOW_PLAN_RECORD_ID=replace-with-plan-record-id
# QINTOPIA_XIAOMAN_ACTIVITY_SHADOW_OCCURRENCE_RECORD_ID=replace-with-occurrence-record-id
# Optional guarded production parity capture. This reads Feishu Base only when
# set to 1, writes 0600 JSON evidence under QINTOPIA_XIAOMAN_ACTIVITY_PARITY_DIR,
# and compares legacy-shaped Base output against wrapper shadow output.
QINTOPIA_XIAOMAN_ACTIVITY_PARITY_ENABLE=0
QINTOPIA_XIAOMAN_ACTIVITY_PARITY_DATE=2026-06-28
QINTOPIA_XIAOMAN_ACTIVITY_PARITY_DIR=/tmp/qintopia-xiaoman-activity-parity

# Huabaosi image generation remains disabled until owner-reviewed provider, isolated
# media storage, staging smoke, budget, and rollback configuration exist. Do not use
# release/deploy artifact storage for generated posters.
QINTOPIA_HUABAOSI_IMAGE_GENERATION_ENABLED=0
# QINTOPIA_HUABAOSI_IMAGE_PROVIDER=replace-with-approved-provider
# QINTOPIA_HUABAOSI_IMAGE_MODEL=replace-with-approved-model
# QINTOPIA_HUABAOSI_IMAGE_API_BASE_URL=https://approved-image-provider.example/v1
# QINTOPIA_HUABAOSI_IMAGE_API_KEY=replace-with-server-secret
# QINTOPIA_HUABAOSI_MEDIA_UPLOAD_ENDPOINT=https://approved-media.example/upload
# QINTOPIA_HUABAOSI_MEDIA_PUBLIC_BASE_URL=https://approved-media.example
# QINTOPIA_HUABAOSI_MEDIA_ALLOWED_HOSTS=approved-media.example
# QINTOPIA_HUABAOSI_MEDIA_MAX_BYTES=10485760
# Guarded staging smoke only. Keep these unset in production and pass the enable flag and
# approval phrase from the reviewed staging command, not from this env file.
# QINTOPIA_HUABAOSI_IMAGE_STAGING_ENV_FILE=/etc/qintopia/message-sidecar-staging.env
# QINTOPIA_HUABAOSI_IMAGE_STAGING_DATABASE_URL_SHA256=replace-with-staging-database-url-sha256
# QINTOPIA_HUABAOSI_IMAGE_STAGING_WORK_ITEM_ID=replace-with-approved-staging-work-item-uuid
# QINTOPIA_HUABAOSI_IMAGE_STAGING_SMOKE_ENABLE=0
# QINTOPIA_HUABAOSI_IMAGE_STAGING_APPROVAL=approved-staging-image-generation

# Huabaosi WeCom canary gateway remains disabled and unscheduled in production. Default
# production binaries exclude the non-default huabaosi-wecom-canary-gateway Cargo
# feature, so setting these env values cannot enable a live send. Use exact allowlists
# only for an owner-reviewed staging command; keep enable and approval unset here.
# QINTOPIA_HUABAOSI_WECOM_CANARY_ENABLED=0
# QINTOPIA_HUABAOSI_WECOM_CANARY_APPROVAL=approved-huabaosi-wecom-canary
# QINTOPIA_HUABAOSI_WECOM_CANARY_ENDPOINT=https://approved-wecom-canary.example/send
# QINTOPIA_HUABAOSI_WECOM_CANARY_TOKEN=replace-with-server-secret
# QINTOPIA_HUABAOSI_WECOM_CANARY_ALLOWED_BOT_IDS=replace-with-canary-bot-id
# QINTOPIA_HUABAOSI_WECOM_CANARY_ALLOWED_CHAT_IDS=replace-with-canary-chat-id
# QINTOPIA_HUABAOSI_WECOM_CANARY_ALLOWED_USER_IDS=replace-with-canary-user-id

# QiWe image sending remains disabled. The reviewed contract uses the official async
# URL upload plus Webhook correlation before /msg/sendImage. Do not enable it until the
# callback returns complete file credentials in an owner-reviewed staging decision. The
# generated-image contract already requires a deterministic final JPEG; staging must
# still verify that exact JPEG and the callback credential shape together. Default and
# production binaries exclude the non-default qiwe-staging-adapter Cargo feature, so
# setting these env values cannot enable a live call. No listener, service, or timer is
# installed.
QINTOPIA_QIWE_IMAGE_SEND_ENABLED=0
QINTOPIA_QIWE_IMAGE_SEND_WEBHOOK_READY=0
# Staging-feature apply only. Keep unset in production and provide it only in the
# owner-reviewed one-shot command.
# QINTOPIA_QIWE_IMAGE_SEND_STAGING_APPROVAL=approved-staging-qiwe-image-send
# QIWE_API_URL=https://manager.qiweapi.com/qiwe/api/qw/doApi
# QIWE_TOKEN=replace-with-server-secret
# QIWE_GUID=replace-with-server-device-guid
# QINTOPIA_QIWE_IMAGE_SEND_ALLOWED_HOSTS=manager.qiweapi.com
# Also requires the reviewed QINTOPIA_HUABAOSI_MEDIA_ALLOWED_HOSTS configured above.
# QINTOPIA_OPERATIONS_ALLOWED_GROUP_IDS=replace-with-reviewed-group-id

RUST_LOG=info,qintopia_message_sidecar=debug
